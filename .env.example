# ============================================================
# INFANT JESUS SPAK - Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# ── SUPABASE ──────────────────────────────────────────────────
# From: Supabase Dashboard > Project Settings > API

# Public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (SERVER ONLY - never in browser, never in NEXT_PUBLIC_)
# Used by Route Handlers and server-side logic
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── APP CONFIG ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── OPTIONAL ─────────────────────────────────────────────────
# School name for branding (currently hardcoded but can be env-driven)
# NEXT_PUBLIC_SCHOOL_NAME="Infant Jesus"
# NEXT_PUBLIC_COMPETITION_TITLE="SPAK Competition"
